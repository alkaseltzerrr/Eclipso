// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  username    String   @unique
  password    String
  avatar      String?
  isOnboarded Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  interests        UserInterest[]
  sentMessages     Message[]         @relation("MessageSender")
  receivedMessages Message[]         @relation("MessageReceiver")
  capsules         Capsule[]
  capsuleUnlockVotes CapsuleUnlockVote[]
  partnerships     Partnership[]     @relation("PartnershipUser")
  partnerOf        Partnership[]     @relation("PartnershipPartner")

  @@map("users")
}

model Interest {
  id       String @id @default(cuid())
  name     String @unique
  category String
  icon     String?

  users UserInterest[]

  @@map("interests")
}

model UserInterest {
  id         String @id @default(cuid())
  userId     String
  interestId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interest Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@unique([userId, interestId])
  @@map("user_interests")
}

model Partnership {
  id        String   @id @default(cuid())
  userId    String
  partnerId String
  status    String   @default("pending") // pending, active, inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User @relation("PartnershipUser", fields: [userId], references: [id], onDelete: Cascade)
  partner User @relation("PartnershipPartner", fields: [partnerId], references: [id], onDelete: Cascade)

  messages Message[]
  capsules Capsule[]

  @@unique([userId, partnerId])
  @@map("partnerships")
}

model Message {
  id            String   @id @default(cuid())
  content       String
  type          String   @default("text") // text, capsule, system
  senderId      String
  receiverId    String
  partnershipId String?
  createdAt     DateTime @default(now())

  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User         @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  partnership  Partnership? @relation(fields: [partnershipId], references: [id], onDelete: SetNull)

  @@map("messages")
}

model Capsule {
  id            String   @id @default(cuid())
  title         String
  content       String
  type          String   @default("text") // text, image, audio
  isLocked      Boolean  @default(false)
  unlockedAt    DateTime?
  createdById   String
  partnershipId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  partnership Partnership? @relation(fields: [partnershipId], references: [id], onDelete: SetNull)
  unlockVotes CapsuleUnlockVote[]

  @@map("capsules")
}

model CapsuleUnlockVote {
  id        String   @id @default(cuid())
  capsuleId String
  userId    String
  createdAt DateTime @default(now())

  capsule Capsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([capsuleId, userId])
  @@map("capsule_unlock_votes")
}

model ConstellationData {
  id            String   @id @default(cuid())
  partnershipId String
  stars         Json     // Store star positions and connections as JSON
  orbitLevel    Int      @default(50)
  updatedAt     DateTime @updatedAt

  @@unique([partnershipId])
  @@map("constellation_data")
}